24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-emerald-500\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> 해외 호스팅 최적화 및 레이턴시 개선</li></ul><button class=\"w-full py-4 bg-emerald-600 text-white font-black rounded-2xl hover:bg-emerald-500 transition-all\">글로벌 트랙 마스터</button></div><div id=\"track-e\" class=\"scroll-mt-32 bg-white dark:bg-slate-900 rounded-3xl border-2 border-slate-200 dark:border-white/20 p-8 space-y-6 hover:border-primary transition-all group shadow-sm\"><div class=\"flex justify-between items-center\"><div class=\"inline-flex bg-slate-100 dark:bg-white/10 text-slate-600 dark:text-slate-300 text-[12px] font-black px-3 py-1 rounded-full uppercase tracking-widest\">Track E</div><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-cpu w-5 h-5 text-primary\"><rect width=\"16\" height=\"16\" x=\"4\" y=\"4\" rx=\"2\"></rect><rect width=\"6\" height=\"6\" x=\"9\" y=\"9\" rx=\"1\"></rect><path d=\"M15 2v2\"></path><path d=\"M15 20v2\"></path><path d=\"M2 15h2\"></path><path d=\"M2 9h2\"></path><path d=\"M20 15h2\"></path><path d=\"M20 9h2\"></path><path d=\"M9 2v2\"></path><path d=\"M9 20v2\"></path></svg></div><div><h4 class=\"text-2xl font-black text-slate-800 dark:text-white mb-2\">고급 AI 활용</h4><p class=\"text-sm text-slate-500 leading-relaxed\">자체 LLM 활용 및 고성능 AI 인프라(GPU) 활용 구조를 이해합니다.</p></div><ul class=\"space-y-3 pt-2\"><li class=\"flex items-center gap-2 text-xs text-slate-600 dark:text-slate-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> 개인 서버 내 LLM 배포 및 튜닝 기초</li><li class=\"flex items-center gap-2 text-xs text-slate-600 dark:text-slate-400\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> NVIDIA NIM 및 가속 인프라 연결 전략</li></ul><button class=\"w-full py-4 bg-slate-900 dark:bg-white/20 text-white font-black rounded-2xl hover:bg-primary transition-all\">AI 마스터 트랙</button></div></div></div><div class=\"pt-8 border-t border-border flex justify-between\"><a href=\"/curriculum/practice\"><button class=\"bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-400 px-8 py-3 rounded-xl font-bold flex items-center gap-2 hover:bg-slate-200 transition-all\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4 rotate-180\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg> 3. 실전 단계로</button></a><div class=\"text-xs font-bold text-slate-400 italic flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-crown w-4 h-4 text-amber-500\"><path d=\"M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z\"></path><path d=\"M5 21h14\"></path></svg> 모든 단계를 완료하셨습니다!<